# zkorage backend — copy to .env (gitignored) and fill in.

# Stellar
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Public RPC the trust-minimized "verify it yourself" channels point at (page + CLI recipe).
PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Contracts. VERIFIER + TOKEN unchanged since Week 1/2; POLICY redeployed in Week 3 (history +
# upgradeable). GATE is the Week-5 relying-party KYC gate — set it to the ID printed by
# contract/scripts/deploy_gate.sh. IDENTITY_IMAGE_ID is the canonical identity guest image it pins.
VERIFIER_CONTRACT_ID=CBAPC663PTWIWDLYNCG5WAD5MIZF4SKY43U6L2NM5ZUU5XFOS4JDYAFW
TOKEN_CONTRACT_ID=CC3JKNC4EKALMT7WALUMCTVBSH73ZZSP3AC4B7IQUAZ7UYYZCEIISQLA
POLICY_CONTRACT_ID=CDQ2PA27UTJDLPA4XTGG647SNTMUYO2KRFGS3SW5SMNBIWRB7JVCZXQ6
GATE_CONTRACT_ID=CCTHDSEQFMAOPJXI5GVSUTMXO5DHZUJS7YQYAEIGKFMOAMTNDKSL4FWT
IDENTITY_IMAGE_ID=a5198a5a359359b08dc1b0faa260e253d413dea5035c1375d19b742f7deaeb3b
# COMPLIANCE is the Week-6 KYC∧not-sanctioned gate — set it to the ID printed by
# contract/scripts/deploy_compliance.sh. COMPLIANCE_IMAGE_ID is the canonical compliance guest it pins.
COMPLIANCE_CONTRACT_ID=CDSA3PUL7OZ5HKLIT73ZTG64TLYK4QTO5ZHZKHA3JBS76R5L5Q2EO4FV
COMPLIANCE_IMAGE_ID=54d5921c58280b63ef80905ffe6d4e506f77031b53ff2a347fe84ace423cb129
# Sanctions deny-list IMT depth (the backend tree-builder is the deny_root authority). Default 20.
DENY_DEPTH=20

# A funded testnet account used as the read-only simulation source AND the token admin.
SIM_SOURCE_PUBKEY=GDLECNXD76OZQROASQGWEP4KAMJWTJXZW2LN7OJGYPXIJDRXACWGXZY6
ADMIN_ADDRESS=GDLECNXD76OZQROASQGWEP4KAMJWTJXZW2LN7OJGYPXIJDRXACWGXZY6

# Server signing key (S...). Signs/pays the policy submit + token mint/burn txs.
# Week-2 MVP only; Freighter client-signing lands in Week 3. NEVER commit a real key.
SIGNER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Prover gateway (RISC0 host) via the VM's Cloudflare tunnel.
PROVER_URL=https://prover.wazowsky.id

# Demo issuer key (32-byte hex seed). Mocked; swap for a real attester. NEVER commit a real key.
ISSUER_SEED=0707070707070707070707070707070707070707070707070707070707070707

PORT=8787

# Week 7 — Confidential payroll (gate + canonical payroll guest image it pins).
PAYROLL_CONTRACT_ID=CA6XYNHYR3GS3TQ24Z2Y45SXRNQDA5Z4L2PU54YM2WUKSMPVWVMYZCDA
PAYROLL_IMAGE_ID=2c9cc61b0dc261290209067783365842eca14b77981486eb535bbacfbd1e2785

# Week 8 — Fundraising (composition): accredited gate (identity leg) + fundraise contract + image ids.
ACCREDITED_CONTRACT_ID=CCLSXZBOPCAJQS6L54EAGZQHTD5QUES2OSYCFX5XJT6ZXSICRPS4QKQZ
FUNDRAISE_CONTRACT_ID=CDEV4METH74Z42DFV6HC3VLF3PWACXVIIS7C3PLK6CZT2B6L5I3YBC2L
ACCREDITED_IMAGE_ID=26d743739468287991220d6da2cb891616aa7c6b90da2eda9836395f31bcc947
REVENUE_IMAGE_ID=973c983125ad3a9f115b2f4d8d12ec39e3f1b107f15c57643f72baf36f923502
FUNDRAISE_THRESHOLD=1000000

# DR1 — Confidential Data Room (data plane). DATAROOM_IMAGE_ID is the canonical seal guest the contract pins.
DATAROOM_CONTRACT_ID=CDUQITRVJOPJNVWBUINLZFI2LHPOLVFW2I7354WEFDG2W3VIG627HLNN
DATAROOM_IMAGE_ID=8f24842d0647a0671ed1b898f6a42c2d104ff04b3f152067c93d9449bf65a3ce

# Cloudflare R2 — blob storage for the encrypted ciphertext (content-addressed by sha256(ciphertext)).
# LEAVE BLANK to use the LOCAL stand-in (backend/data/blobs) — the slice is fully self-testable without R2.
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=zkorage-dataroom
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
