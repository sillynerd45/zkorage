# Production build config (Vite auto-loads this only for `vite build`, not `vite dev`).
# The static `serve` build has NO dev proxy, so the SPA must call the public backend directly.
# Consumed via import.meta.env.VITE_BACKEND_URL in src/api.ts + src/pages/dataroom/shared.tsx
# (fallback "/api" in dev). Public hostname, not a secret.
VITE_BACKEND_URL=https://apizk.wazowsky.id
