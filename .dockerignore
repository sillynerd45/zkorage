# Both images build from the repo root (so the backend can resolve its file:../sdk dependency).
# Keep the context lean — exclude everything the FE/BE images don't need. NOTE: do NOT blanket-exclude
# **/dist — sdk/dist (backend dep) and frontend/dist (the served build) are both required.

.git
.gitignore
CLAUDE.md
README.md

# Large local-only trees + other subprojects not part of the FE/BE images. keyper/ IS needed (the keeper
# image builds from this same root context), so it is NOT excluded — only its node_modules + share-store
# data dir are (below). The FE/BE images don't COPY keyper/, so the small extra context is harmless.
development/
contract/
prover/
mcp/
keeper/

# Keeper: source IS needed by deploy/keyper.Dockerfile; its share-store data + deps are not baked in.
keyper/data
keyper/.env

# Deps / build caches (re-installed inside the image)
**/node_modules
**/target
**/*.tsbuildinfo
**/*.log
**/.cache

# Backend secrets + state come in at RUNTIME (env_file + data volume), never baked into the image
backend/.env
backend/.env.example
backend/data

# Frontend: only dist/ + serve.json are needed by the serve image
frontend/src
frontend/tests
frontend/public
frontend/index.html
frontend/vite.config.ts
frontend/tsconfig*.json
frontend/playwright.config.ts
frontend/.env
frontend/.env.*
frontend/.gitignore
